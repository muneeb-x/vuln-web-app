# Continue with Google (OAuth 2.0) — copy this file to `.env` and fill in.
#
# Where to get these values:
#   Google Cloud Console → Google Auth Platform → Clients
#   → Create OAuth client → Web application
#   (full walkthrough: docs/continue-with-google-explained.md, section 5)
#
# The real `.env` is git-ignored — never commit your actual secret.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an "Authorized redirect URI" registered in the console
# (same scheme, host, port, and path — no trailing slash):
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Optional: seconds to wait on Google's network endpoints (default 10).
# OAUTH_HTTP_TIMEOUT=10


# Email Verification on Signup (SMTP) — copy to `.env` and fill in.
#
# Sign-up requires email so the app can send a verification link; with these
# unset, the signup page shows a friendly "not configured" message.
#
# Gmail quick start:
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password (https://myaccount.google.com/apppasswords).
#   3. Put the 16-character app password in SMTP_PASSWORD below.
#
# The real `.env` is git-ignored — never commit your actual secret.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-address@gmail.com

# Public base URL used to build the verification link (no trailing slash):
APP_BASE_URL=http://localhost:3001

# Optional: SMTP network timeout in seconds (default 10).
# SMTP_TIMEOUT=10
# Optional: verification-token lifetime in seconds (default 3600 = 1 hour).
# EMAIL_VERIFICATION_TTL_SECONDS=3600


# Account Lockout (v1.0.5) — env-tunable, NOT secrets.
#
# After this many CONSECUTIVE failed logins against one account, it is locked
# for the duration below; the lock then expires on its own. This per-account
# control complements (does not replace) the per-IP rate limiter. The app works
# with these unset — the defaults shown here apply. Lower both to demo quickly,
# e.g. ACCOUNT_LOCKOUT_MAX_ATTEMPTS=3 and ACCOUNT_LOCKOUT_DURATION_SECONDS=30.
# ACCOUNT_LOCKOUT_MAX_ATTEMPTS=6
# ACCOUNT_LOCKOUT_DURATION_SECONDS=3600


# Email OTP 2FA (v1.0.6) — env-tunable, NOT secrets.
#
# When a user enables Email OTP 2FA on their profile, a correct password emails a
# 6-digit code; login completes only after the code is verified. OTP delivery
# reuses the SMTP settings above (no separate gate). The app works with these
# unset — the defaults shown apply. Lower them to demo quickly, e.g.
# OTP_TTL_SECONDS=30 and OTP_RESEND_COOLDOWN_SECONDS=5.
# OTP_TTL_SECONDS=300
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SECONDS=60
