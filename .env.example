# Continue with Google (OAuth 2.0) — copy this file to `.env` and fill in.
#
# Where to get these values:
#   Google Cloud Console → Google Auth Platform → Clients
#   → Create OAuth client → Web application
#   (full walkthrough: docs/continue-with-google-explained.md, section 5)
#
# The real `.env` is git-ignored — never commit your actual secret.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an "Authorized redirect URI" registered in the console
# (same scheme, host, port, and path — no trailing slash):
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Optional: seconds to wait on Google's network endpoints (default 10).
# OAUTH_HTTP_TIMEOUT=10


# Email Verification + OTP (SendGrid) — copy to `.env` and fill in.
#
# Email is sent ONLY through SendGrid's HTTPS API (works on hosts that block
# outbound SMTP, e.g. Render). With these unset, the signup page shows a friendly
# "not configured" message.
#
# SendGrid quick start:
#   1. Create a SendGrid account and a Single Sender (verify the From address),
#      or verify a domain.
#   2. Settings → API Keys → Create API Key (Mail Send permission).
#   3. Put the key in SENDGRID_API_KEY and the verified address in SENDGRID_FROM.
#
# The real `.env` is git-ignored — never commit your actual secret.

SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM=your-verified-sender@example.com

# Public base URL used to build the verification link (no trailing slash):
APP_BASE_URL=http://localhost:3001

# Optional: SendGrid API timeout in seconds (default 10).
# SENDGRID_HTTP_TIMEOUT=10
# Optional: verification-token lifetime in seconds (default 3600 = 1 hour).
# EMAIL_VERIFICATION_TTL_SECONDS=3600


# Account Lockout (v1.0.5) — env-tunable, NOT secrets.
#
# After this many CONSECUTIVE failed logins against one account, it is locked
# for the duration below; the lock then expires on its own. This per-account
# control complements (does not replace) the per-IP rate limiter. The app works
# with these unset — the defaults shown here apply. Lower both to demo quickly,
# e.g. ACCOUNT_LOCKOUT_MAX_ATTEMPTS=3 and ACCOUNT_LOCKOUT_DURATION_SECONDS=30.
# ACCOUNT_LOCKOUT_MAX_ATTEMPTS=6
# ACCOUNT_LOCKOUT_DURATION_SECONDS=3600


# Email OTP 2FA (v1.0.6) — env-tunable, NOT secrets.
#
# When a user enables Email OTP 2FA on their profile, a correct password emails a
# 6-digit code; login completes only after the code is verified. OTP delivery
# reuses the SMTP settings above (no separate gate). The app works with these
# unset — the defaults shown apply. Lower them to demo quickly, e.g.
# OTP_TTL_SECONDS=30 and OTP_RESEND_COOLDOWN_SECONDS=5.
# OTP_TTL_SECONDS=300
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SECONDS=60


# MFA via Authenticator App (TOTP) (v1.0.7) — env-tunable, NOT secrets.
#
# When a user enrolls an authenticator app (Google Authenticator, Authy, ...), a
# correct password issues a TOTP challenge instead of completing login. TOTP needs
# NEITHER SMTP NOR Google — it works on a fresh clone with these unset (the
# defaults shown apply). These only tune the issuer label shown in the app and the
# clock-drift tolerance. The code length (6) and secret size (160-bit) are fixed.
# TOTP_ISSUER=Security Vulnerability Lab
# TOTP_PERIOD_SECONDS=30
# TOTP_SKEW_STEPS=1


# QR Code Login (v1.0.8) — env-tunable, NOT secrets.
#
# An unauthenticated browser is shown a QR on /login; an already-signed-in device
# scans it and approves, logging the first browser in. Needs NEITHER SMTP NOR
# Google and adds NO new dependency — it works on a fresh clone with these unset
# (the defaults shown apply). For a real cross-device scan, set APP_BASE_URL above
# to an address the scanning device can reach (LAN IP / public origin), not
# localhost; on localhost "scan" by opening the link in a second logged-in browser.
# QR_LOGIN_TTL_SECONDS=120
# QR_LOGIN_POLL_INTERVAL_SECONDS=2


# CAPTCHA on Login (Cloudflare Turnstile, v2.0.0) — copy to `.env` and fill in.
#
# Adds a Turnstile widget to the login form; POST /login is verified server-side
# (stdlib urllib, no new dependency) BEFORE any password check. With these UNSET
# the login page shows no widget and login works exactly as today (graceful
# degrade). The SITE key is public; the SECRET key is a real secret — the real
# `.env` is git-ignored, never commit it. A configured-but-unreachable verify
# endpoint fails OPEN (allows login) so a Cloudflare outage can't lock everyone out.
#
# Where to get these (free, no domain needed):
#   https://dash.cloudflare.com → Turnstile → Add widget
#   Hostname: localhost   (add your real domain for production)
#   Widget mode: Managed  → copy the Site Key and Secret Key below.
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Optional: siteverify network timeout in seconds (default 10).
# TURNSTILE_HTTP_TIMEOUT=10
